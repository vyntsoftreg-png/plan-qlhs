# ============================================
# QLHS Backend Environment Variables Template
# ============================================
# Copy this file to .env and fill in real values
# NEVER commit .env to version control!

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
HOSTNAME=localhost
API_VERSION=v1

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qlhs_db
DB_USER=qlhs_user
DB_PASSWORD=your_very_secure_password_here_change_this
DB_POOL_MIN=5
DB_POOL_MAX=10
DB_SSL=false

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=your_access_secret_key_min_32_chars_change_this
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars_change_this
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# ============================================
# FILE STORAGE (Cloudinary)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=qlhs/images

# ============================================
# EMAIL (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_not_real_password
SMTP_FROM_NAME=QLHS
SMTP_FROM_EMAIL=noreply@qlhs.vn

# ============================================
# API SECURITY
# ============================================
# CORS Origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:5000,https://qlhs.dev.vn
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# INITIAL ADMIN SETUP
# ============================================
# Set SETUP_ENABLED=true ONLY when creating the first admin account.
# Set back to false (or remove) immediately after setup is complete.
# Generate SETUP_SECRET with: openssl rand -hex 32
SETUP_ENABLED=false
SETUP_SECRET=change_this_to_a_strong_random_secret_value

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_DIR=./logs

# ============================================
# API DOCUMENTATION
# ============================================
SWAGGER_ENABLED=true
SWAGGER_URL=/api-docs

# ============================================
# PAYMENT (Future Phase)
# ============================================
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLIC_KEY=pk_test_xxx

# ============================================
# ENVIRONMENT-SPECIFIC
# ============================================
# Development
# (Keep defaults above)

# Staging
# NODE_ENV=staging
# DB_HOST=db-staging.rds.amazonaws.com
# CORS_ORIGIN=https://staging.qlhs.dev.vn

# Production
# NODE_ENV=production
# DB_HOST=db-prod.rds.amazonaws.com
# CORS_ORIGIN=https://qlhs.vn
# LOG_LEVEL=warn
